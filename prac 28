Set 28 
Consider following structure for Mongodb collection and write a query for following requirements in 
Mongodb  
Teachers (Tname,dno,Experience,Salary,Date_of_Joining)  
Department (Dno,Dname)  
Students(Sname,Roll_No,Class)  
1. Write a query to create above collection insert some sample documents.  
2. Find the information about all teachers of Dno=2 and having salary greater than or equal to 10,000/-  
3. Find the student information having Roll_no=2 or Sname='xyz'  
4. Update student name whose Roll_No=5  
5. Delete all student whose Class is 'FE'  
6. Apply index on Students Collection  


use schooldb

db.createCollection("teachers")
db.createCollection("department")
db.createCollection("students")

// Insert sample documents

db.teachers.insertMany([
{
tname:"Om",
dno:2,
experience:5,
salary:15000,
date_of_joining:"2024-01-01"
},
{
tname:"Krushna",
dno:2,
experience:3,
salary:12000,
date_of_joining:"2023-05-01"
}
])

db.department.insertMany([
{
dno:2,
dname:"Computer"
}
])

db.students.insertMany([
{
sname:"xyz",
roll_no:2,
class:"FE"
},
{
sname:"Pooja",
roll_no:5,
class:"SE"
}
])

// 1. Find teachers with Dno=2 and salary >=10000

db.teachers.find(
{
dno:2,
salary:{$gte:10000}
}
)

// 2. Find students with Roll_No=2 or Sname='xyz'

db.students.find(
{
$or:[
{roll_no:2},
{sname:"xyz"}
]
}
)

// 3. Update student name whose Roll_No=5

db.students.updateOne(
{
roll_no:5
},
{
$set:{sname:"Rahul"}
}
)

// 4. Delete students whose class is FE

db.students.deleteMany(
{
class:"FE"
}
)

// 5. Create index on students collection

db.students.createIndex(
{
sname:1
}
)
