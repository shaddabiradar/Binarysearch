1. Create a table dept1 as below with following columns: 
DEPTNO integer pk, dname varchar2(30) not null, loc varchar2(30) not null 
2.Add column mgr as number in the dept table. 
3. Create table empl with following columns  
empno integer ,ename varchar2(20) ,sal number(10,2) ,deptno number  
4. Add constraints on  empl table 
Empno-primary key 
Ename-not null 
Check sal>10000 
Deptno as foreign key 
5.Create table dept11,emp11 from dept1,empl 
6.Add a new column address varchar2(30) in the empl table 
7.Rename sal column in empl table to salary 
8.Display constraints names and verify the names for the empl 




CREATE TABLE dept1 (
    deptno NUMBER PRIMARY KEY,
    dname VARCHAR2(30) NOT NULL,
    loc VARCHAR2(30) NOT NULL
);

ALTER TABLE dept1
ADD mgr NUMBER;

CREATE TABLE emp1 (
    empno NUMBER,
    ename VARCHAR2(20),
    sal NUMBER(10,2),
    deptno NUMBER
);

ALTER TABLE emp1
ADD CONSTRAINT emp1_pk PRIMARY KEY (empno);

ALTER TABLE emp1
MODIFY ename VARCHAR2(20) NOT NULL;

ALTER TABLE emp1
ADD CONSTRAINT emp1_sal_chk CHECK (sal > 10000);

ALTER TABLE emp1
ADD CONSTRAINT emp1_dept_fk
FOREIGN KEY (deptno) REFERENCES dept1(deptno);

CREATE TABLE dept11 AS
SELECT * FROM dept1;

CREATE TABLE emp11 AS
SELECT * FROM emp1;

ALTER TABLE emp1
ADD address VARCHAR2(30);

ALTER TABLE emp1
RENAME COLUMN sal TO salary;

