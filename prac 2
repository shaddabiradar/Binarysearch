SELECT C.Cname, A.Acc_Type, A.Amount
FROM Customer C
JOIN Account A
ON C.C_Id = A.C_Id
WHERE A.Acc_Type = 'Saving';
SELECT *
FROM Customer
NATURAL JOIN Account;
SELECT *
FROM Customer C
LEFT JOIN Account A
ON C.C_Id = A.C_Id;
SELECT *
FROM Customer C
RIGHT JOIN Account A
ON C.C_Id = A.C_Id;
