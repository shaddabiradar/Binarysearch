DECLARE
    rno NUMBER;
    bname VARCHAR2(30);
    issue_date DATE;
    days NUMBER;
    fine_amt NUMBER := 0;

BEGIN
    rno := &roll_no;
    bname := '&book_name';

    SELECT DateofIssue
    INTO issue_date
    FROM Borrower
    WHERE Rollin = rno
    AND NameofBook = bname;

    days := SYSDATE - issue_date;

    IF days BETWEEN 15 AND 30 THEN
        fine_amt := days * 5;

    ELSIF days > 30 THEN
        fine_amt := (30 * 5) + ((days - 30) * 50);

    ELSE
        fine_amt := 0;
    END IF;

    UPDATE Borrower
    SET Status = 'R'
    WHERE Rollin = rno
    AND NameofBook = bname;

    IF fine_amt > 0 THEN

        INSERT INTO Fine
        VALUES (rno, SYSDATE, fine_amt);

        DBMS_OUTPUT.PUT_LINE('Fine Amount = ' || fine_amt);

    ELSE

        DBMS_OUTPUT.PUT_LINE('No Fine');

    END IF;

EXCEPTION

    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Record not found');

    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Error occurred');

END;
