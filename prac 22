CREATE OR REPLACE PROCEDURE proc_Grade
(
    rno NUMBER,
    sname VARCHAR2,
    marks NUMBER
)
IS
    class1 VARCHAR2(30);

BEGIN

    IF marks <= 1500 AND marks >= 990 THEN
        class1 := 'Distinction';

    ELSIF marks BETWEEN 900 AND 989 THEN
        class1 := 'First Class';

    ELSIF marks BETWEEN 825 AND 899 THEN
        class1 := 'Higher Second Class';

    ELSE
        class1 := 'Fail';

    END IF;

    INSERT INTO Result
    VALUES (rno, sname, class1);

END;
/
DECLARE
    rno NUMBER;
    sname VARCHAR2(20);
    marks NUMBER;

BEGIN

    rno := &roll_no;

    SELECT Name, Total_Marks
    INTO sname, marks
    FROM Stud_Marks
    WHERE Roll = rno;

    proc_Grade(rno, sname, marks);

    DBMS_OUTPUT.PUT_LINE('Grade inserted successfully');

EXCEPTION

    WHEN NO_DATA_FOUND THEN
        DBMS_OUTPUT.PUT_LINE('Student not found');

    WHEN OTHERS THEN
        DBMS_OUTPUT.PUT_LINE('Error occurred');

END;
